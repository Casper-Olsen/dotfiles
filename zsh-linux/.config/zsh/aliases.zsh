# Set personal aliases, overriding those provided by Oh My Zsh libs, plugins, and themes.
alias vim="nvim"

# When Fedora ships Neovim 0.12, switch back to the packaged version:
#   rm ~/.local/bin/nvim
#   hash -r
#   sudo dnf upgrade neovim
#   nvim --version
# If that shows Fedora's 0.12, the AppImage install can be removed:
#   rm -r ~/.local/opt/nvim/0.12
